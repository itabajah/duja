// Duja flyout — presentation only (plan §4.4). All logic lives in the Rust
// view-models; this file maps model rows to widgets and widget events back to
// callbacks. Design rules baked in:
//   * Premium-minimal: 4/8 px spacing grid, one accent colour, subtle radii.
//   * NO Timer elements and no idle animations (perf budget: zero idle wakeups).
//     Short, interaction-driven easing only (hover/press/thumb), which wakes the
//     loop solely while the user is interacting.
//   * Light/dark palettes defined once in `Palette`; the `dark` property flips
//     them live.
//   * Every user-visible string goes through @tr(...) for i18n from day one.
//   * Keyboard: sliders take arrow keys, Tab traverses, Esc emits esc-pressed.

import { ScrollView } from "std-widgets.slint";

// One monitor row, mirroring `duja_ui::flyout_vm::FlyoutRow`.
export struct FlyoutRowData {
    name: string,
    percent: int,
    kind: string,
    greyed: bool,
    slider-enabled: bool,
    // Feature 1: software-dimming toggle + floor marker.
    dimming-on: bool,
    has-floor: bool,
    // Line B: where hardware hands off to software dimming (the floor). 0..=1.
    marker-fraction: float,
    // Line A: where hardware brightness reaches zero (the perceptual anchor). 0..=1.
    marker-a-fraction: float,
    // Whether lines A and B coincide (floor 0) — then only one line is drawn.
    markers-coincide: bool,
}

// Both palettes in one place; `dark` selects between them at render time. Tuned
// for contrast in both themes, including the greyed/unresponsive treatment.
export global Palette {
    in property <bool> dark: true;

    // Neutrals carry a subtle warm tint (hue nudged toward red at the same
    // lightness) so the whole surface reads warm rather than cool-blue. The light
    // ramp is stepped a little deeper than a bare off-white so the white cards,
    // hairline borders and off-state pills separate clearly from the surface
    // instead of washing out (a light-theme visibility pass).
    out property <color> bg: dark ? #1a1719 : #ece9eb;
    out property <color> surface: dark ? #262327 : #ffffff;
    out property <color> surface-hover: dark ? #2e2a2e : #f2edf0;
    out property <color> surface-greyed: dark ? #201d1f : #e5dfe2;
    out property <color> text: dark ? #f4f2f4 : #1a171a;
    out property <color> text-subtle: dark ? #9c9a9e : #6d6a6e;
    out property <color> text-faint: dark ? #706d72 : #837f86;
    out property <color> border: dark ? #3a353a : #d8d1d5;
    out property <color> border-strong: dark ? #4c464c : #c4bcc0;
    // The accent family. Unlike the neutrals these are *inputs*, pushed from Rust
    // by both shells (`duja_ui::accent` is the single source of truth, and the same
    // table colours the tray/taskbar icons). They are resolved against the theme on
    // the Rust side, so — unlike every `dark ? … : …` below — they carry no
    // conditional here. The defaults are ruby-dark, so the frame before the first
    // render already looks right.
    in property <color> accent: #f2555a;
    in property <color> accent-hover: #ff6d72;
    // Low-opacity accent used for the sub-floor (software-dimming) track zone.
    in property <color> accent-soft: #f2555a4d;
    // The foreground drawn ON TOP of an `accent` fill (the pill knob, a primary
    // button's label). White is unreadable on a light-luminance accent — it scores
    // under 2:1 on Gold, Emerald and Onyx in dark — so Rust picks white or ink per
    // accent and theme rather than it being hardcoded at the call sites.
    in property <color> accent-on: #ffffff;
    out property <color> track: dark ? #403a40 : #d4ccd0;
    out property <color> track-dead: dark ? #2f2a2f : #c5bdc1;
    out property <color> thumb: #ffffff;
    out property <color> marker: dark ? #f4f2f4 : #403a40;
    // Line A (hardware zero) reads quieter than line B (the transition).
    out property <color> marker-soft: dark ? #f4f2f480 : #403a4059;
    // The accent glow around the thumb on hover/press (premium touch).
    out property <color> thumb-glow: accent;
    // The value bubble shown while dragging.
    out property <color> bubble-bg: dark ? #2e2a2e : #ffffff;
    out property <color> bubble-border: dark ? #4c464c : #c4bcc0;
    // Asymmetric by design: the ring lifts to the bright accent on dark, but stays
    // the base accent on light (where the bright end is too pale to read).
    out property <color> focus-ring: dark ? accent-hover : accent;
    // A distinct red for error/unresponsive states, kept clearly apart from the
    // ruby accent in both themes: in dark it reads lighter/pinker than the accent;
    // in light the accent is already a bright coral, so danger separates by going
    // the other way — a deeper, more saturated red.
    out property <color> danger: dark ? #ff9d9d : #b42318;
    // A crisp 1px window-edge stroke so a borderless (no-frame) window still reads
    // as a distinct window against a same-coloured app behind it (item 4). Tuned
    // to contrast against the window's own bg in each theme.
    out property <color> window-edge: dark ? #4a4a56 : #bfb8bc;
}

// A square, keyboard-focusable icon button (header/footer chrome).
export component IconButton inherits Rectangle {
    in property <string> icon;
    in property <string> label;
    callback clicked();

    // Sized via *literal* min/max so a parent layout gives it exactly 30px. A
    // property-bound min/max is not picked up by Slint's layout constraint
    // resolution (unlike a literal), which silently collapses the button.
    min-width: 30px;
    max-width: 30px;
    min-height: 30px;
    max-height: 30px;
    border-radius: 8px;
    background: touch.has-hover ? Palette.surface-hover : transparent;
    animate background { duration: 120ms; }
    border-width: fs.has-focus ? 2px : 0px;
    border-color: Palette.focus-ring;
    forward-focus: fs;
    accessible-role: button;
    accessible-label: label;
    accessible-action-default => { root.clicked(); }

    Text {
        text: icon;
        font-size: 15px;
        color: Palette.text-subtle;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    fs := FocusScope {
        key-pressed(event) => {
            if (event.text == " " || event.text == "\n") {
                root.clicked();
                return accept;
            }
            return reject;
        }
    }
    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            fs.focus();
            root.clicked();
        }
    }
}

// A compact custom on/off pill (per-row software-dimming toggle). Custom rather
// than std Switch so it fits the row without a bolted-on label.
export component PillToggle inherits Rectangle {
    in property <bool> checked;
    in property <bool> enabled: true;
    in property <string> label;
    callback toggled(bool);

    min-width: 38px;
    max-width: 38px;
    min-height: 21px;
    max-height: 21px;
    border-radius: 10.5px;
    opacity: enabled ? 1.0 : 0.45;
    background: checked ? Palette.accent : Palette.track;
    animate background { duration: 130ms; }
    border-width: fs.has-focus ? 2px : 0px;
    border-color: Palette.focus-ring;
    forward-focus: fs;
    accessible-role: switch;
    accessible-checked: checked;
    accessible-label: label;
    accessible-action-default => {
        if (enabled) { root.toggled(!root.checked); }
    }

    knob := Rectangle {
        width: 15px;
        height: 15px;
        border-radius: 7.5px;
        y: 3px;
        x: checked ? parent.width - self.width - 3px : 3px;
        animate x { duration: 130ms; easing: ease-out; }
        // When checked the knob sits ON the accent fill, so it must contrast with
        // the accent, not the track — a white knob disappears on a light accent
        // (Onyx-dark scores 1.2:1). `accent-on` is white for every accent that can
        // carry it, so this is a no-op for ruby.
        background: root.checked ? Palette.accent-on : Palette.thumb;
    }

    fs := FocusScope {
        enabled: root.enabled;
        key-pressed(event) => {
            if (event.text == " " || event.text == "\n") {
                root.toggled(!root.checked);
                return accept;
            }
            return reject;
        }
    }
    TouchArea {
        enabled: root.enabled;
        mouse-cursor: pointer;
        clicked => {
            fs.focus();
            root.toggled(!root.checked);
        }
    }
}

// A themed dropdown (custom, not the std `ComboBox`) so it draws from *our*
// `Palette` in both themes and sizes identically everywhere. The std widget
// reads Slint's own Fluent palette, which follows the OS colour-scheme rather
// than our app theme — its label went invisible on the light theme (a real
// light-mode bug) and it could never follow the accent. Fixed 34px height and
// `min-width` so every dropdown across the app (theme, accent, dim mode, input)
// is the same size.
export component Dropdown inherits Rectangle {
    in property <[string]> model;
    in property <int> current-index;
    in property <bool> enabled: true;
    in property <string> label;
    callback selected(/* index */ int);

    min-width: 158px;
    max-width: 158px;
    min-height: 34px;
    max-height: 34px;
    border-radius: 8px;
    opacity: enabled ? 1.0 : 0.5;
    background: touch.has-hover ? Palette.surface-hover : Palette.surface;
    animate background { duration: 120ms; }
    border-width: fs.has-focus ? 2px : 1px;
    border-color: fs.has-focus ? Palette.focus-ring : Palette.border-strong;
    forward-focus: fs;
    accessible-role: combobox;
    accessible-label: root.label;
    accessible-expandable: true;
    accessible-expanded: popup-open;
    accessible-action-expand => {
        popup.show();
    }

    // Tracks the popup so keyboard users can tell it is open (a11y) and so the
    // chevron can flip. Set true on show, reset by the popup's `close` handler.
    property <bool> popup-open;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 10px;
        spacing: 6px;
        Text {
            text: (root.current-index >= 0 && root.current-index < root.model.length)
                ? root.model[root.current-index] : "";
            color: Palette.text;
            font-size: 13px;
            vertical-alignment: center;
            horizontal-alignment: left;
            horizontal-stretch: 1;
            overflow: elide;
        }
        Text {
            text: root.popup-open ? "▴" : "▾";
            color: Palette.text-subtle;
            font-size: 13px;
            vertical-alignment: center;
        }
    }

    popup := PopupWindow {
        x: 0;
        y: parent.height + 4px;
        width: root.width;
        // Close when the user clicks elsewhere; an item click closes explicitly
        // (below) after it has been delivered to the row's TouchArea.
        close-policy: close-on-click-outside;
        Rectangle {
            background: Palette.surface;
            border-radius: 8px;
            border-width: 1px;
            border-color: Palette.border-strong;
            drop-shadow-blur: 14px;
            drop-shadow-color: #00000059;
            VerticalLayout {
                padding: 4px;
                for item[idx] in root.model: Rectangle {
                    height: 30px;
                    border-radius: 6px;
                    background: item-touch.has-hover ? Palette.surface-hover
                        : (idx == root.current-index ? Palette.surface-greyed : transparent);
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 6px;
                        Text {
                            text: item;
                            color: Palette.text;
                            font-size: 13px;
                            vertical-alignment: center;
                            horizontal-alignment: left;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }
                        // A quiet tick on the current row.
                        Text {
                            text: idx == root.current-index ? "✓" : "";
                            color: Palette.accent;
                            font-size: 13px;
                            vertical-alignment: center;
                        }
                    }
                    item-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.selected(idx);
                            root.popup-open = false;
                            popup.close();
                        }
                    }
                }
            }
        }
    }

    fs := FocusScope {
        enabled: root.enabled;
        key-pressed(event) => {
            if (event.text == " " || event.text == "\n") {
                root.popup-open = true;
                popup.show();
                return accept;
            }
            // Arrow keys change the selection in place without opening the popup,
            // matching the std widget's keyboard behaviour.
            if (event.text == Key.DownArrow) {
                if (root.current-index < root.model.length - 1) {
                    root.selected(root.current-index + 1);
                }
                return accept;
            }
            if (event.text == Key.UpArrow) {
                if (root.current-index > 0) {
                    root.selected(root.current-index - 1);
                }
                return accept;
            }
            return reject;
        }
    }
    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: pointer;
        clicked => {
            fs.focus();
            root.popup-open = true;
            popup.show();
        }
    }
}

// A generic accent-following slider over an arbitrary `[minimum, maximum]` range
// (custom, not the std `Slider`, which draws Slint's Fluent accent and never
// followed our theme accent). Simpler than `BrightnessSlider` — no floor marker,
// sub-floor zone, value bubble or glide — for the per-monitor calibration rows.
export component TrackSlider inherits Rectangle {
    in property <float> value;
    in property <float> minimum: 0;
    in property <float> maximum: 100;
    in property <bool> enabled: true;
    in property <string> label;
    callback changed(/* value */ float);

    min-width: 120px;
    min-height: 24px;
    max-height: 24px;
    horizontal-stretch: 1;
    opacity: enabled ? 1.0 : 0.5;
    forward-focus: fs;
    accessible-role: slider;
    accessible-label: root.label;
    accessible-value: root.value;
    accessible-value-minimum: root.minimum;
    accessible-value-maximum: root.maximum;
    accessible-value-step: 1;

    property <length> thumb-size: 14px;
    property <length> track-h: 5px;
    property <length> usable: root.width - thumb-size;
    // Guard against a zero span (minimum == maximum) dividing by zero.
    property <float> span: max(root.maximum - root.minimum, 0.001);
    property <float> frac: clamp((root.value - root.minimum) / span, 0, 1);
    property <bool> active: touch.pressed;

    function set-from-pointer() {
        if (!root.enabled) {
            return;
        }
        root.changed(root.minimum + clamp((touch.mouse-x - thumb-size / 2) / usable, 0, 1) * span);
    }
    function nudge(delta: float) {
        root.changed(clamp(root.value + delta, root.minimum, root.maximum));
    }

    // Track base.
    Rectangle {
        x: root.thumb-size / 2;
        width: root.usable;
        height: root.track-h;
        y: (parent.height - self.height) / 2;
        border-radius: self.height / 2;
        background: Palette.track;
    }
    // Accent-following fill.
    Rectangle {
        x: root.thumb-size / 2;
        width: root.usable * root.frac;
        height: root.track-h;
        y: (parent.height - self.height) / 2;
        border-radius: self.height / 2;
        background: @linear-gradient(90deg, Palette.accent 0%, Palette.accent-hover 100%);
    }
    // Thumb with the same accent glow as the brightness slider.
    Rectangle {
        width: root.thumb-size;
        height: root.thumb-size;
        border-radius: self.width / 2;
        y: (parent.height - self.height) / 2;
        x: root.usable * root.frac;
        background: Palette.thumb;
        border-width: 1px;
        border-color: Palette.border-strong;
        drop-shadow-blur: (root.active || touch.has-hover) ? 8px : 2px;
        drop-shadow-color: (root.active || touch.has-hover) ? Palette.thumb-glow : #00000040;
        animate drop-shadow-blur { duration: 120ms; }
        animate drop-shadow-color { duration: 120ms; }
    }
    // Focus ring around the whole track when keyboard-focused.
    if fs.has-focus: Rectangle {
        x: 0;
        width: root.width;
        height: root.track-h + 12px;
        y: (parent.height - self.height) / 2;
        border-radius: self.height / 2;
        border-width: 2px;
        border-color: Palette.focus-ring;
        background: transparent;
    }

    fs := FocusScope {
        enabled: root.enabled;
        key-pressed(event) => {
            if (event.text == Key.RightArrow || event.text == Key.UpArrow) {
                root.nudge(1);
                return accept;
            }
            if (event.text == Key.LeftArrow || event.text == Key.DownArrow) {
                root.nudge(-1);
                return accept;
            }
            return reject;
        }
    }
    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: pointer;
        moved => {
            root.set-from-pointer();
        }
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down) {
                fs.focus();
                root.set-from-pointer();
            }
        }
    }
}

// A themed text button (custom, not the std `Button`) so it draws from *our*
// `Palette` and follows the accent when `primary`. Sizes to its label, so it
// suits variable-width actions ("Check now", "Open releases page").
export component TextButton inherits Rectangle {
    in property <string> text;
    in property <bool> primary;
    in property <bool> enabled: true;
    // A richer label for screen readers; falls back to the visible text.
    in property <string> label;
    callback clicked();

    min-height: 32px;
    max-height: 32px;
    border-radius: 8px;
    opacity: enabled ? 1.0 : 0.5;
    background: primary
        ? (touch.has-hover ? Palette.accent-hover : Palette.accent)
        : (touch.has-hover ? Palette.surface-hover : Palette.surface);
    animate background { duration: 120ms; }
    border-width: primary ? 0px : 1px;
    border-color: fs.has-focus ? Palette.focus-ring : Palette.border-strong;
    forward-focus: fs;
    accessible-role: button;
    accessible-label: root.label == "" ? root.text : root.label;
    accessible-action-default => {
        if (root.enabled) {
            root.clicked();
        }
    }

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        Text {
            text: root.text;
            // A primary label sits ON the accent fill (use `accent-on`); a
            // secondary one sits on the surface (use `text`, dimmed when disabled).
            color: root.primary ? Palette.accent-on : Palette.text;
            font-size: 13px;
            font-weight: 600;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }

    fs := FocusScope {
        enabled: root.enabled;
        key-pressed(event) => {
            if (event.text == " " || event.text == "\n") {
                root.clicked();
                return accept;
            }
            return reject;
        }
    }
    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: pointer;
        clicked => {
            fs.focus();
            root.clicked();
        }
    }
}

// The brightness slider with a hardware-floor handoff marker. Custom (not the
// std Slider) so it can draw the marker and the two-tone sub-floor zone, and so
// a mid-drag pointer grab is never disturbed by an external `value` write: while
// pressed the thumb follows the pointer and ignores model writes to `value`
// (consistent with the P0 in-place model-sync fix).
export component BrightnessSlider inherits Rectangle {
    in property <float> value;            // 0..=100 user level
    in property <bool> enabled: true;
    in property <bool> marker-visible;
    in property <float> marker-fraction;  // 0..=1 line B (hardware/software handoff)
    in property <float> marker-a-fraction; // 0..=1 line A (hardware zero)
    in property <bool> markers-coincide;  // A == B (floor 0) ⇒ draw one line
    in property <bool> dimming-on;
    // Glide duration (ms) for an external value change; 0 = instant (drag / hidden
    // / reduced-motion). Driven by the app from the OS animation setting.
    in property <int> glide-ms;
    callback changed(float);

    min-width: 120px;
    min-height: 28px;
    max-height: 28px;
    horizontal-stretch: 1;
    opacity: enabled ? 1.0 : 0.5;
    forward-focus: fs;
    accessible-role: slider;
    accessible-label: @tr("Brightness");
    accessible-value: root.value;
    accessible-value-minimum: 0;
    accessible-value-maximum: 100;
    accessible-value-step: 1;

    property <length> thumb-size: 16px;
    property <length> track-h: 6px;
    property <length> usable: root.width - thumb-size;
    // Below the floor with dimming off the slider bottoms out at the floor.
    property <float> min-fraction: (!dimming-on && marker-visible) ? marker-fraction : 0;
    property <bool> active: touch.pressed;
    property <float> drag-value: value;
    property <float> shown: active ? drag-value : value;
    property <float> shown-frac: shown / 100;
    // Glide only an external change: never while dragging (0), never on a hidden
    // window / reduced motion (the app passes glide-ms 0 then).
    property <duration> glide: (root.active ? 0 : root.glide-ms) * 1ms;
    // Hover-near-a-marker, derived from the main touch area's pointer position so
    // no overlapping TouchArea steals the drag. Off while dragging.
    property <bool> hover-a: touch.has-hover && !root.active
        && abs(touch.mouse-x - (root.thumb-size / 2 + root.usable * root.marker-a-fraction)) < 8px;
    property <bool> hover-b: touch.has-hover && !root.active
        && abs(touch.mouse-x - (root.thumb-size / 2 + root.usable * root.marker-fraction)) < 8px;

    function set-from-pointer() {
        if (!root.enabled) {
            return;
        }
        root.drag-value = clamp((touch.mouse-x - root.thumb-size / 2) / root.usable, root.min-fraction, 1.0) * 100;
        root.changed(root.drag-value);
    }
    function nudge(delta: float) {
        root.changed(clamp(root.value + delta, root.min-fraction * 100, 100));
    }

    // Track base.
    Rectangle {
        x: root.thumb-size / 2;
        width: root.usable;
        height: root.track-h;
        y: (parent.height - self.height) / 2;
        border-radius: self.height / 2;
        background: Palette.track;

        // Sub-floor zone (0..line B): dimming on ⇒ soft accent tint (the
        // software-dimming range); dimming off ⇒ dead/greyed zone.
        if root.marker-visible: Rectangle {
            x: 0;
            width: root.usable * root.marker-fraction;
            height: parent.height;
            border-radius: parent.border-radius;
            background: root.dimming-on ? Palette.accent-soft : Palette.track-dead;
        }
    }

    // Filled portion above line B (hardware regime): an accent gradient that
    // brightens toward full, for a premium sheen.
    Rectangle {
        x: root.thumb-size / 2;
        width: root.usable * root.shown-frac;
        height: root.track-h;
        y: (parent.height - self.height) / 2;
        border-radius: self.height / 2;
        background: @linear-gradient(90deg, Palette.accent 0%, Palette.accent-hover 100%);
        animate width { duration: root.glide; easing: ease-out; }
    }
    // The part of the fill that sits below line B reads dimmer (software regime)
    // so the two regimes are legible.
    if root.marker-visible && root.dimming-on: Rectangle {
        x: root.thumb-size / 2;
        width: root.usable * clamp(root.shown-frac, 0, root.marker-fraction);
        height: root.track-h;
        y: (parent.height - self.height) / 2;
        border-radius: self.height / 2;
        background: Palette.accent-soft;
        animate width { duration: root.glide; easing: ease-out; }
    }

    // Line A (hardware zero): a quieter tick, drawn only when it is distinct from
    // line B (a non-zero floor). At floor 0 the two coincide and only B is drawn.
    if root.marker-visible && !root.markers-coincide: Rectangle {
        x: root.thumb-size / 2 + root.usable * root.marker-a-fraction - self.width / 2;
        width: 2px;
        height: root.track-h + 6px;
        y: (parent.height - self.height) / 2;
        border-radius: 1px;
        background: Palette.marker-soft;
    }

    // Line B (hardware ⇄ software handoff): the primary marker.
    if root.marker-visible: Rectangle {
        x: root.thumb-size / 2 + root.usable * root.marker-fraction - self.width / 2;
        width: 2px;
        height: root.track-h + 8px;
        y: (parent.height - self.height) / 2;
        border-radius: 1px;
        background: Palette.marker;
    }

    // Hover-a-marker label chips (hovering the line explains it). Positioned below
    // the track; only one shows at a time and never while dragging.
    if root.hover-a && !root.markers-coincide: Rectangle {
        x: clamp(root.thumb-size / 2 + root.usable * root.marker-a-fraction - self.width / 2, 0px, root.width - self.width);
        y: root.height - 2px;
        width: label-a.preferred-width + 12px;
        height: 18px;
        border-radius: 5px;
        background: Palette.bubble-bg;
        border-width: 1px;
        border-color: Palette.bubble-border;
        label-a := Text {
            text: @tr("Hardware minimum");
            font-size: 10px;
            color: Palette.text-subtle;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
    if root.hover-b: Rectangle {
        x: clamp(root.thumb-size / 2 + root.usable * root.marker-fraction - self.width / 2, 0px, root.width - self.width);
        y: root.height - 2px;
        width: label-b.preferred-width + 12px;
        height: 18px;
        border-radius: 5px;
        background: Palette.bubble-bg;
        border-width: 1px;
        border-color: Palette.bubble-border;
        label-b := Text {
            text: root.markers-coincide ? @tr("Hardware minimum") : @tr("Software dimming starts");
            font-size: 10px;
            color: Palette.text-subtle;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Thumb, with an accent glow that intensifies on hover / press.
    Rectangle {
        width: root.thumb-size;
        height: root.thumb-size;
        border-radius: self.width / 2;
        y: (parent.height - self.height) / 2;
        x: root.usable * root.shown-frac;
        background: Palette.thumb;
        border-width: 1px;
        border-color: Palette.border-strong;
        drop-shadow-blur: (root.active || touch.has-hover) ? 10px : 3px;
        drop-shadow-color: (root.active || touch.has-hover) ? Palette.thumb-glow : #00000040;
        animate drop-shadow-blur { duration: 120ms; }
        animate drop-shadow-color { duration: 120ms; }
        animate x { duration: root.glide; easing: ease-out; }
    }

    // Value bubble: a floating readout above the thumb while dragging.
    if root.active: Rectangle {
        x: clamp(root.usable * root.shown-frac + root.thumb-size / 2 - self.width / 2, 0px, root.width - self.width);
        y: -28px;
        width: 46px;
        height: 22px;
        border-radius: 7px;
        background: Palette.bubble-bg;
        border-width: 1px;
        border-color: Palette.bubble-border;
        drop-shadow-blur: 8px;
        drop-shadow-color: #00000033;
        Text {
            text: "\{round(root.shown)}%";
            font-size: 12px;
            font-weight: 700;
            color: (root.marker-visible && root.shown-frac < root.marker-fraction) ? Palette.text-subtle : Palette.text;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Focus ring around the whole track when keyboard-focused.
    if fs.has-focus: Rectangle {
        x: 0;
        width: root.width;
        height: root.track-h + 12px;
        y: (parent.height - self.height) / 2;
        border-radius: self.height / 2;
        border-width: 2px;
        border-color: Palette.focus-ring;
        background: transparent;
    }

    fs := FocusScope {
        enabled: root.enabled;
        key-pressed(event) => {
            if (event.text == Key.RightArrow || event.text == Key.UpArrow) {
                root.nudge(1);
                return accept;
            }
            if (event.text == Key.LeftArrow || event.text == Key.DownArrow) {
                root.nudge(-1);
                return accept;
            }
            return reject;
        }
    }
    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: pointer;
        moved => {
            root.set-from-pointer();
        }
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down) {
                fs.focus();
                root.set-from-pointer();
            }
        }
    }
}

export component FlyoutWindow inherits Window {
    title: @tr("Duja Brightness");
    // Slim, tray-flyout proportions on an 8 px grid. A touch wider than a bare
    // slider so the inline per-row dimming toggle has room (item 2).
    width: 360px;
    // Height driven by the app (no-frame windows are not auto-grown to content).
    height: clamp(root.content-height, 160px, 620px);
    background: Palette.bg;
    no-frame: true;

    // --- inputs from the Rust shell (set from FlyoutVm state) ---
    in property <[FlyoutRowData]> rows;
    in property <bool> no-displays;
    in property <bool> dark <=> Palette.dark;
    // The accent family, pushed by the shell. A Slint global is instantiated once
    // per component tree, so the flyout and settings windows own *independent*
    // `Palette`s — both must alias and both shells must push, or only one window
    // recolours (see `flyout_palette_follows_the_selected_accent`).
    in property <color> accent <=> Palette.accent;
    in property <color> accent-hover <=> Palette.accent-hover;
    in property <color> accent-soft <=> Palette.accent-soft;
    in property <color> accent-on <=> Palette.accent-on;
    in-out property <bool> link-all;
    // The desired window height (logical px), computed by the app from the row
    // count (a no-frame window is not auto-grown to its content preferred size).
    in property <length> content-height: 260px;
    // Repaint anchor, flipped by the shell on every present (see the window-edge
    // Rectangle below and `FlyoutShell::present_at`): toggling it marks the whole
    // window dirty so the software renderer presents a *complete* frame, curing
    // the blank/partial first paint on tray re-open.
    in property <bool> present-nonce;
    // Glide duration (ms) for external brightness changes; the app sets it from
    // the OS animation preference (0 = reduced motion / instant).
    in property <int> glide-ms;

    // --- outputs to the Rust shell (mapped onto FlyoutVm calls) ---
    callback slider-changed(/* row-index */ int, /* percent */ float);
    callback dimming-toggled(/* row-index */ int, /* on */ bool);
    callback link-toggled(/* on */ bool);
    callback refresh-requested();
    callback settings-clicked();
    callback close-requested();
    callback esc-pressed();

    forward-focus: scope;
    scope := FocusScope {
        // Esc hides the flyout; everything else falls through to the widgets.
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.esc-pressed();
                return accept;
            }
            return reject;
        }

        // 1px window-edge border (item 4): a no-frame window otherwise blends into
        // a same-coloured app behind it. Drawn behind the content (fills the
        // window; the 14px content padding leaves the 1px rim visible), so it never
        // intercepts pointer input. Square corners keep the opaque, software-
        // rendered window free of transparent-corner artifacts.
        //
        // Doubles as the repaint anchor: its `background` depends on
        // `present-nonce`, and because it fills the whole window a change here
        // marks the entire window dirty — forcing the software renderer to present
        // a complete frame rather than a stale partial-damage region (the first-
        // paint bug). The two alpha values (0 and 1/255) are visually identical
        // over the opaque window yet genuinely different, so the compiler cannot
        // fold the dependency and every flip repaints.
        Rectangle {
            background: root.present-nonce ? #00000001 : #00000000;
            border-width: 1px;
            border-color: Palette.window-edge;
        }

        VerticalLayout {
            padding: 14px;
            spacing: 10px;
            // No `alignment: start`: the body ScrollView below carries
            // `vertical-stretch` and fills the slack, so the cards pack to the top
            // inside it and it scrolls once the window hits its max height.

            // Header: wordmark (stretch) + link-all toggle + settings gear +
            // close. Link-all moved up from the retired footer, reclaiming a row
            // of height. (Manual "refresh displays" is still wired via
            // `refresh-requested` but not surfaced — hot-plug auto-refreshes.)
            HorizontalLayout {
                spacing: 6px;
                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    Text {
                        text: @tr("Duja");
                        font-size: 17px;
                        font-weight: 800;
                        color: Palette.text;
                        horizontal-alignment: left;
                        accessible-role: text;
                        accessible-label: @tr("Duja");
                    }
                    Text {
                        text: @tr("Brightness");
                        font-size: 11px;
                        font-weight: 500;
                        color: Palette.text-faint;
                        horizontal-alignment: left;
                        // Decorative wordmark subtitle: keep it out of the a11y tree
                        // so it doesn't shadow the slider's "Brightness" label.
                        accessible-role: none;
                    }
                }
                // Link-all: a captioned pill, centred at its natural 21px height
                // (a HorizontalLayout would otherwise stretch it to the 30px row).
                VerticalLayout {
                    alignment: center;
                    HorizontalLayout {
                        spacing: 6px;
                        Text {
                            text: @tr("Link all");
                            color: Palette.text-subtle;
                            font-size: 11px;
                            vertical-alignment: center;
                            // Right-align + no stretch so the glyphs hug the pill
                            // instead of the layout padding the text box out.
                            horizontal-alignment: right;
                            horizontal-stretch: 0;
                            // Decorative caption for the link-all pill (which carries
                            // the label); keep it out of the a11y tree.
                            accessible-role: none;
                        }
                        PillToggle {
                            // One-way (not `<=>`): the shell owns the state — it
                            // updates the VM and re-renders `link-all`, like the
                            // per-row dimming toggle. A two-way binding here froze
                            // the pill (P0 live-QA: "Link all does nothing").
                            checked: root.link-all;
                            label: @tr("Link all displays");
                            toggled(on) => {
                                root.link-toggled(on);
                            }
                        }
                    }
                }
                // Breathing room between the link-all control and the window-chrome
                // buttons, so the two groups read as distinct.
                Rectangle {
                    min-width: 12px;
                    max-width: 12px;
                }
                gear := IconButton {
                    icon: "⚙";
                    label: @tr("Settings");
                    clicked => {
                        root.settings-clicked();
                    }
                }
                close := IconButton {
                    icon: "×";
                    label: @tr("Close");
                    clicked => {
                        root.close-requested();
                    }
                }
            }

            // Body: the empty-state or the monitor rows, wrapped in a ScrollView
            // so the window grows to fit the cards up to its max height, then
            // scrolls instead of clipping (item 4, mirroring the settings window).
            // Cards stretch to the width, so only a vertical bar ever appears.
            ScrollView {
                vertical-stretch: 1;
                horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                VerticalLayout {
                    spacing: 8px;
                    // Pack cards to the top at their natural height: the ScrollView
                    // makes its viewport at least as tall as the visible area, so
                    // without this the surplus would stretch every card (dead space
                    // below the slider) instead of sitting harmlessly at the bottom.
                    alignment: start;

                    // Empty-state, shown only when there are no displays.
                    if root.no-displays: Rectangle {
                        height: 96px;
                border-radius: 12px;
                background: Palette.surface;
                border-width: 1px;
                border-color: Palette.border;
                VerticalLayout {
                    alignment: center;
                    spacing: 4px;
                    Text {
                        text: "🖥";
                        font-size: 24px;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: @tr("No displays detected");
                        color: Palette.text;
                        font-size: 13px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        accessible-role: text;
                        accessible-label: @tr("No displays detected");
                    }
                    Text {
                        text: @tr("Connect a display to get started.");
                        color: Palette.text-subtle;
                        font-size: 11px;
                        horizontal-alignment: center;
                    }
                }
            }

                    // Monitor rows. The empty `for` renders nothing when there
                    // are no displays, so it needs no `if` guard of its own.
                    for row[idx] in root.rows: Rectangle {
                        background: row.greyed ? Palette.surface-greyed
                            : (card-hover.has-hover ? Palette.surface-hover : Palette.surface);
                        animate background { duration: 120ms; }
                        border-radius: 12px;
                        border-width: 1px;
                        border-color: Palette.border;
                        opacity: row.greyed ? 0.6 : 1.0;
                        accessible-role: groupbox;
                        accessible-label: row.name + ", " + row.kind + ", " + row.percent + @tr(" percent");

                        card-hover := TouchArea {
                            mouse-cursor: default;
                            enabled: false;
                        }

                        VerticalLayout {
                            padding: 12px;
                            spacing: 8px;

                            // Name / kind on the left; the software-dimming caption
                            // on the right, bottom-aligned so it sits just above its
                            // pill (on the slider row below) with a comfortable gap.
                            // The caption column matches the pill column width below,
                            // so the two line up as one stacked control.
                            HorizontalLayout {
                                spacing: 6px;
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 1px;
                                    Text {
                                        text: row.name;
                                        color: Palette.text;
                                        font-size: 13px;
                                        font-weight: 600;
                                        overflow: elide;
                                    }
                                    Text {
                                        text: row.greyed ? @tr("Unresponsive") : row.kind;
                                        color: row.greyed ? Palette.danger : Palette.text-faint;
                                        font-size: 10px;
                                        font-weight: 500;
                                    }
                                }
                                VerticalLayout {
                                    min-width: 54px;
                                    max-width: 54px;
                                    alignment: end;
                                    Text {
                                        text: @tr("Software dimming");
                                        color: Palette.text-subtle;
                                        font-size: 9px;
                                        wrap: word-wrap;
                                        horizontal-alignment: center;
                                        // Decorative caption for the pill (which
                                        // carries the label); keep it out of the a11y
                                        // tree so it isn't announced twice.
                                        accessible-role: none;
                                    }
                                }
                            }

                            // Slider + software-dimming pill, side by side (item 2).
                            // The slider stretches; the pill sits at its natural 21px,
                            // vertically centred on the slider's 28px row (level with
                            // the track), in a column the same width as the caption
                            // above it.
                            HorizontalLayout {
                                spacing: 6px;
                                BrightnessSlider {
                                    value: row.percent;
                                    enabled: row.slider-enabled;
                                    dimming-on: row.dimming-on;
                                    marker-visible: row.has-floor;
                                    marker-fraction: row.marker-fraction;
                                    marker-a-fraction: row.marker-a-fraction;
                                    markers-coincide: row.markers-coincide;
                                    glide-ms: root.glide-ms;
                                    changed(v) => {
                                        root.slider-changed(idx, v);
                                    }
                                }
                                // Nest the pill so neither dimension is stretched by
                                // the column's slack: the outer VerticalLayout centres
                                // it vertically (natural 21px height, not the 28px
                                // row) and the inner HorizontalLayout centres it
                                // horizontally (natural 38px width, not the 54px
                                // column). This is exactly how the header "Link all"
                                // pill is wrapped, so the two pills are identical.
                                VerticalLayout {
                                    min-width: 54px;
                                    max-width: 54px;
                                    alignment: center;
                                    HorizontalLayout {
                                        alignment: center;
                                        PillToggle {
                                            checked: row.dimming-on;
                                            enabled: row.slider-enabled;
                                            label: @tr("Software dimming");
                                            toggled(on) => {
                                                root.dimming-toggled(idx, on);
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
