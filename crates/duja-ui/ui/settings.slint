// Duja settings window — presentation only (plan §4.4). All logic lives in
// `duja_ui::settings_vm::SettingsVm`; this file maps VM state to widgets and
// widget events back to callbacks. Same design rules as the flyout:
//   * Premium-minimal: 4/8 px spacing grid, one accent colour, subtle radii.
//   * NO Timer elements and no idle animations (perf budget: zero idle wakeups).
//   * Shared `Palette` + components (imported from flyout.slint) flip themes live.
//   * Every user-visible string goes through @tr(...) for i18n from day one.
//   * Keyboard: Esc emits esc-pressed; Tab traverses; widgets take arrow keys.

import { Slider, ComboBox, ScrollView, Button } from "std-widgets.slint";
import { Palette, IconButton, PillToggle } from "flyout.slint";

// One per-monitor section, mirroring `duja_ui::settings_vm::MonitorSection`.
export struct SettingsMonitorData {
    name: string,
    floor-pct: int,
    min-perceived-pct: int,
    dim-mode-index: int,
    gamma-available: bool,
    inputs: [string],
    has-inputs: bool,
}

// One editable hotkey row, mirroring `duja_ui::settings_vm::HotkeyRow`.
export struct SettingsHotkeyData {
    action: string,
    binding: string,
    conflicted: bool,
    unavailable: bool,
}

// A titled card section wrapper.
component Section inherits Rectangle {
    in property <string> title;
    background: Palette.surface;
    border-radius: 14px;
    border-width: 1px;
    border-color: Palette.border;

    VerticalLayout {
        padding: 16px;
        spacing: 12px;
        Text {
            text: root.title;
            font-size: 12px;
            font-weight: 700;
            color: Palette.text-subtle;
            // A quiet, letter-spaced section header.
            accessible-role: text;
            accessible-label: root.title;
        }
        @children
    }
}

// A small labelled text button used for record / clear affordances.
component MiniButton inherits Rectangle {
    in property <string> text;
    in property <bool> primary;
    callback clicked();
    min-height: 28px;
    max-height: 28px;
    min-width: 66px;
    border-radius: 8px;
    background: primary
        ? (touch.has-hover ? Palette.accent-hover : Palette.accent)
        : (touch.has-hover ? Palette.surface-hover : transparent);
    animate background { duration: 120ms; }
    border-width: primary ? 0px : 1px;
    border-color: fs.has-focus ? Palette.focus-ring : Palette.border-strong;
    forward-focus: fs;
    accessible-role: button;
    accessible-label: root.text;
    accessible-action-default => { root.clicked(); }
    Text {
        text: root.text;
        font-size: 12px;
        font-weight: 600;
        color: root.primary ? #ffffff : Palette.text;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    fs := FocusScope {
        key-pressed(event) => {
            if (event.text == " " || event.text == "\n") {
                root.clicked();
                return accept;
            }
            return reject;
        }
    }
    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            fs.focus();
            root.clicked();
        }
    }
}

// A label + control row on the 8px grid.
component FieldRow inherits HorizontalLayout {
    in property <string> label;
    spacing: 8px;
    Text {
        text: root.label;
        color: Palette.text;
        font-size: 13px;
        vertical-alignment: center;
        horizontal-stretch: 1;
    }
    @children
}

export component SettingsWindow inherits Window {
    title: @tr("Duja Settings");
    width: 440px;
    height: clamp(root.content-height, 340px, 820px);
    background: Palette.bg;
    // Frameless like the flyout; the header is a drag handle (see below) and the
    // ✕ / Esc close it. Keyboard resize/minimize are intentionally not offered.
    no-frame: true;

    // --- inputs from the Rust shell (set from SettingsVm state) ---
    in property <bool> dark <=> Palette.dark;
    // The desired window height (logical px), driven by the app.
    in property <length> content-height: 600px;
    // Repaint anchor, flipped by the shell on every present (see the window-edge
    // Rectangle below and `SettingsShell::present_at`): toggling it marks the
    // whole window dirty so the software renderer presents a *complete* frame,
    // curing the blank/partial first paint on re-open.
    in property <bool> present-nonce;
    in-out property <bool> autostart-on;
    in property <bool> autostart-supported: true;
    in property <int> theme-index;
    in-out property <bool> update-check-on;
    in property <string> update-status;
    in property <bool> update-available;
    in property <[SettingsMonitorData]> monitors;
    in property <[SettingsHotkeyData]> hotkeys;
    // Which hotkey row is currently recording a chord (-1 = none). Written by the
    // Record buttons here and reset by the shell after a successful capture.
    in-out property <int> recording-index: -1;

    // --- outputs to the Rust shell (mapped onto SettingsVm calls) ---
    callback autostart-toggled(/* on */ bool);
    callback theme-selected(/* index */ int);
    callback update-check-toggled(/* on */ bool);
    callback check-updates-clicked();
    callback open-releases-clicked();
    callback monitor-floor-changed(/* monitor-index */ int, /* percent */ float);
    callback monitor-min-perceived-changed(/* monitor-index */ int, /* percent */ float);
    callback monitor-dim-mode-selected(/* monitor-index */ int, /* option */ int);
    callback monitor-input-selected(/* monitor-index */ int, /* option */ int);
    // Feature 3: hotkey record / clear.
    callback hotkey-key-captured(/* row */ int, /* ctrl */ bool, /* alt */ bool, /* shift */ bool, /* meta */ bool, /* token */ string);
    callback hotkey-clear-clicked(/* row */ int);
    callback close-requested();
    callback esc-pressed();
    // Begin a system window move (frameless header drag). Wired to winit's
    // `drag_window` in the shell.
    callback start-drag();

    forward-focus: scope;
    scope := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.esc-pressed();
                return accept;
            }
            return reject;
        }

        // 1px window-edge border (item 4): the frameless settings window otherwise
        // blends into a same-coloured app behind it. Drawn behind the content (the
        // header/section padding leaves the 1px rim visible), so it never
        // intercepts pointer input. Square corners keep the opaque, software-
        // rendered window free of transparent-corner artifacts.
        //
        // Doubles as the repaint anchor (see the flyout): its `background` depends
        // on `present-nonce`, and filling the whole window means a change here
        // marks the entire window dirty — forcing a complete software-renderer
        // present rather than a stale partial-damage region. The two alpha values
        // (0 and 1/255) are visually identical yet genuinely different, so the
        // compiler cannot fold the dependency and every flip repaints.
        Rectangle {
            background: root.present-nonce ? #00000001 : #00000000;
            border-width: 1px;
            border-color: Palette.window-edge;
        }

        VerticalLayout {
            // Header band: a drag handle (frameless window move) carrying the
            // title (stretch) + close. The drag TouchArea sits *under* the
            // content so the close button still receives its own clicks.
            Rectangle {
                drag := TouchArea {
                    mouse-cursor: default;
                    // Start a system move on press; the OS then follows the
                    // pointer until release (no per-frame set-position needed).
                    pointer-event(event) => {
                        if (event.kind == PointerEventKind.down) {
                            root.start-drag();
                        }
                    }
                }
                HorizontalLayout {
                    padding-left: 18px;
                    padding-right: 14px;
                    padding-top: 14px;
                    padding-bottom: 6px;
                    spacing: 8px;
                    VerticalLayout {
                        horizontal-stretch: 1;
                        Text {
                            text: @tr("Settings");
                            font-size: 18px;
                            font-weight: 800;
                            color: Palette.text;
                            horizontal-alignment: left;
                        }
                        Text {
                            text: @tr("Duja");
                            font-size: 11px;
                            color: Palette.text-faint;
                            horizontal-alignment: left;
                        }
                    }
                    IconButton {
                        icon: "×";
                        label: @tr("Close");
                        clicked => {
                            root.close-requested();
                        }
                    }
                }
            }

            ScrollView {
                VerticalLayout {
                    padding: 14px;
                    spacing: 12px;

                    // ---------------- General ----------------
                    Section {
                        title: @tr("GENERAL");
                        FieldRow {
                            label: @tr("Start with Windows");
                            PillToggle {
                                checked <=> root.autostart-on;
                                enabled: root.autostart-supported;
                                label: @tr("Start with Windows");
                                toggled(on) => {
                                    root.autostart-toggled(on);
                                }
                            }
                        }
                        FieldRow {
                            label: @tr("Theme");
                            ComboBox {
                                model: [@tr("Auto"), @tr("Light"), @tr("Dark")];
                                current-index: root.theme-index;
                                accessible-label: @tr("Theme");
                                selected => {
                                    root.theme-selected(self.current-index);
                                }
                            }
                        }
                    }

                    // ---------------- Displays ----------------
                    Section {
                        title: @tr("PER-MONITOR");
                        if root.monitors.length == 0: Text {
                            text: @tr("No displays detected");
                            color: Palette.text-subtle;
                            font-size: 13px;
                        }
                        for monitor[idx] in root.monitors: Rectangle {
                            background: Palette.bg;
                            border-radius: 10px;
                            border-width: 1px;
                            border-color: Palette.border;
                            accessible-role: groupbox;
                            accessible-label: monitor.name;
                            VerticalLayout {
                                padding: 12px;
                                spacing: 8px;
                                Text {
                                    text: monitor.name;
                                    color: Palette.text;
                                    font-size: 14px;
                                    font-weight: 700;
                                    overflow: elide;
                                }
                                FieldRow {
                                    label: @tr("Hardware floor");
                                    Slider {
                                        width: 160px;
                                        minimum: 0;
                                        maximum: 50;
                                        value: monitor.floor-pct;
                                        accessible-label: @tr("Hardware floor");
                                        changed(v) => {
                                            root.monitor-floor-changed(idx, v);
                                        }
                                    }
                                    Text {
                                        text: monitor.floor-pct + "%";
                                        color: Palette.text-subtle;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        width: 34px;
                                        horizontal-alignment: right;
                                    }
                                }
                                FieldRow {
                                    label: @tr("Brightness at hardware minimum");
                                    Slider {
                                        width: 160px;
                                        minimum: 5;
                                        maximum: 60;
                                        value: monitor.min-perceived-pct;
                                        accessible-label: @tr("Brightness at hardware minimum");
                                        changed(v) => {
                                            root.monitor-min-perceived-changed(idx, v);
                                        }
                                    }
                                    Text {
                                        text: monitor.min-perceived-pct + "%";
                                        color: Palette.text-subtle;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        width: 34px;
                                        horizontal-alignment: right;
                                    }
                                }
                                FieldRow {
                                    label: @tr("Dim mode");
                                    ComboBox {
                                        model: [@tr("Overlay"), @tr("Gamma"), @tr("Off")];
                                        current-index: monitor.dim-mode-index;
                                        accessible-label: @tr("Dim mode");
                                        selected => {
                                            root.monitor-dim-mode-selected(idx, self.current-index);
                                        }
                                    }
                                }
                                if !monitor.gamma-available: Text {
                                    text: @tr("Gamma is unavailable while HDR is active");
                                    color: Palette.text-faint;
                                    font-size: 11px;
                                    wrap: word-wrap;
                                }
                                if monitor.has-inputs: FieldRow {
                                    label: @tr("Input source");
                                    ComboBox {
                                        model: monitor.inputs;
                                        accessible-label: @tr("Input source");
                                        selected => {
                                            root.monitor-input-selected(idx, self.current-index);
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // ---------------- Hotkeys ----------------
                    Section {
                        title: @tr("HOTKEYS");
                        for hotkey[idx] in root.hotkeys: Rectangle {
                            background: root.recording-index == idx ? Palette.surface-hover : Palette.bg;
                            animate background { duration: 120ms; }
                            border-radius: 10px;
                            border-width: 1px;
                            border-color: root.recording-index == idx ? Palette.accent : Palette.border;
                            accessible-role: groupbox;
                            accessible-label: hotkey.action;
                            VerticalLayout {
                                padding: 10px;
                                spacing: 6px;
                                HorizontalLayout {
                                    spacing: 8px;
                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        spacing: 2px;
                                        Text {
                                            text: hotkey.action;
                                            color: Palette.text;
                                            font-size: 13px;
                                            font-weight: 600;
                                        }
                                        Text {
                                            text: root.recording-index == idx ? @tr("Press a key combo…")
                                                : (hotkey.binding == "" ? @tr("Not set") : hotkey.binding);
                                            color: root.recording-index == idx ? Palette.accent
                                                : ((hotkey.conflicted || hotkey.unavailable) ? Palette.danger
                                                : (hotkey.binding == "" ? Palette.text-faint : Palette.text-subtle));
                                            font-size: 12px;
                                            font-weight: root.recording-index == idx ? 700 : 500;
                                        }
                                        if hotkey.conflicted: Text {
                                            text: @tr("Conflicts with another action");
                                            color: Palette.danger;
                                            font-size: 10px;
                                        }
                                        if hotkey.unavailable && !hotkey.conflicted: Text {
                                            text: @tr("Unavailable — already used by another app");
                                            color: Palette.danger;
                                            font-size: 10px;
                                        }
                                    }
                                    MiniButton {
                                        text: root.recording-index == idx ? @tr("Stop") : @tr("Record");
                                        primary: root.recording-index == idx;
                                        clicked => {
                                            if (root.recording-index == idx) {
                                                root.recording-index = -1;
                                            } else {
                                                root.recording-index = idx;
                                                capture.focus();
                                            }
                                        }
                                    }
                                    MiniButton {
                                        text: @tr("Clear");
                                        clicked => {
                                            root.recording-index = -1;
                                            root.hotkey-clear-clicked(idx);
                                        }
                                    }
                                }
                                // Armed only while this row is recording (focused).
                                capture := FocusScope {
                                    width: 0px;
                                    height: 0px;
                                    key-pressed(event) => {
                                        if (event.text == Key.Escape) {
                                            root.recording-index = -1;
                                            return accept;
                                        }
                                        // Modifier-only presses keep recording.
                                        if (event.text == Key.Control || event.text == Key.Shift
                                            || event.text == Key.Alt || event.text == Key.Meta
                                            || event.text == Key.ControlR || event.text == Key.ShiftR
                                            || event.text == Key.MetaR || event.text == Key.AltGr) {
                                            return accept;
                                        }
                                        root.hotkey-key-captured(
                                            idx,
                                            event.modifiers.control,
                                            event.modifiers.alt,
                                            event.modifiers.shift,
                                            event.modifiers.meta,
                                            event.text == Key.UpArrow ? "Up"
                                                : event.text == Key.DownArrow ? "Down"
                                                : event.text == Key.LeftArrow ? "Left"
                                                : event.text == Key.RightArrow ? "Right"
                                                : event.text == Key.Space ? "Space"
                                                : event.text == Key.Return ? "Enter"
                                                : event.text == Key.Tab ? "Tab"
                                                : event.text == Key.Home ? "Home"
                                                : event.text == Key.End ? "End"
                                                : event.text == Key.PageUp ? "PageUp"
                                                : event.text == Key.PageDown ? "PageDown"
                                                : event.text == Key.Insert ? "Insert"
                                                : event.text == Key.Delete ? "Delete"
                                                : event.text == Key.Backspace ? "Backspace"
                                                : event.text == Key.F1 ? "F1"
                                                : event.text == Key.F2 ? "F2"
                                                : event.text == Key.F3 ? "F3"
                                                : event.text == Key.F4 ? "F4"
                                                : event.text == Key.F5 ? "F5"
                                                : event.text == Key.F6 ? "F6"
                                                : event.text == Key.F7 ? "F7"
                                                : event.text == Key.F8 ? "F8"
                                                : event.text == Key.F9 ? "F9"
                                                : event.text == Key.F10 ? "F10"
                                                : event.text == Key.F11 ? "F11"
                                                : event.text == Key.F12 ? "F12"
                                                : event.text
                                        );
                                        return accept;
                                    }
                                }
                            }
                        }
                        Text {
                            text: @tr("Click Record, then press a modifier + key (e.g. Ctrl+Alt+Up).");
                            color: Palette.text-faint;
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                    }

                    // ---------------- About & updates ----------------
                    Section {
                        title: @tr("ABOUT & UPDATES");
                        FieldRow {
                            label: @tr("Check for updates");
                            PillToggle {
                                checked <=> root.update-check-on;
                                label: @tr("Check for updates");
                                toggled(on) => {
                                    root.update-check-toggled(on);
                                }
                            }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            Button {
                                text: @tr("Check now");
                                enabled: root.update-check-on;
                                accessible-label: @tr("Check for updates now");
                                clicked => {
                                    root.check-updates-clicked();
                                }
                            }
                            Text {
                                text: root.update-status;
                                color: Palette.text-subtle;
                                font-size: 12px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                                overflow: elide;
                            }
                        }
                        if root.update-available: HorizontalLayout {
                            Button {
                                text: @tr("Open releases page");
                                accessible-label: @tr("Open the releases page in your browser");
                                clicked => {
                                    root.open-releases-clicked();
                                }
                            }
                            Rectangle { horizontal-stretch: 1; }
                        }
                    }
                }
            }
        }
    }
}
